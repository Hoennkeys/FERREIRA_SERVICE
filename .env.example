VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Para npm run db:setup (automático) — use UMA das opções:
# A) Token: https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=sbp_...
# B) Connection string (URI) em Project Settings → Database
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Backend: mock | supabase | auto (default: auto — Supabase com fallback local)
# VITE_CLIENTS_BACKEND=mock
# Host adicional no embed Twitch (se usar domínio próprio além do vercel.app)
# VITE_TWITCH_PARENT_HOST=www.seudominio.com.br
# Twitch — detecção de live (passo a passo: docs/TWITCH_SETUP.md)
# Sem prefixo VITE_ (somente servidor). Client type: Confidential no console.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Cloudflare Turnstile — anti-bot no onboarding (https://dash.cloudflare.com/)
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
